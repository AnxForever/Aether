{
  "name": "@nexus/watcher",
  "version": "1.0.0",
  "description": "Cross-platform file monitoring system with hot reload support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "file-watcher",
    "hot-reload",
    "parcel-watcher",
    "file-monitoring",
    "watch",
    "fsevents",
    "cross-platform"
  ],
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
