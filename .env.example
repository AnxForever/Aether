# Nexus Agent Environment Variables

# =============================================================================
# AI Provider API Keys
# =============================================================================

# Claude (Anthropic) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI - https://platform.openai.com/
OPENAI_API_KEY=sk-xxxxx

# Google Gemini - https://aistudio.google.com/
GOOGLE_API_KEY=xxxxx

# MiniMax - https://www.minimax.chat/
MINIMAX_API_KEY=xxxxx
MINIMAX_GROUP_ID=xxxxx

# Moonshot (Kimi) - https://platform.moonshot.cn/
MOONSHOT_API_KEY=xxxxx

# Zhipu GLM - https://open.bigmodel.cn/
GLM_API_KEY=xxxxx

# DeepSeek - https://platform.deepseek.com/
DEEPSEEK_API_KEY=xxxxx

# =============================================================================
# Google Services (OAuth 2.0)
# =============================================================================

# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# =============================================================================
# GitHub Integration
# =============================================================================

# GitHub Personal Access Token - https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxx

# =============================================================================
# Database & Storage
# =============================================================================

# SQLite database path (relative to data directory)
DB_PATH=nexus.db

# Encryption password for sensitive data
ENCRYPTION_PASSWORD=your-secure-password-here

# =============================================================================
# Server Configuration
# =============================================================================

# HTTP Server
HTTP_PORT=3000
HTTP_HOST=127.0.0.1

# WebSocket Server
WS_PORT=3001

# Enable CORS
CORS_ENABLED=true

# =============================================================================
# Speech & Audio
# =============================================================================

# SenseVoice model path
SENSEVOICE_MODEL_PATH=./models/sensevoice

# TTS Provider (edge-tts, piper, coqui)
TTS_PROVIDER=edge-tts
TTS_VOICE=zh-CN-XiaoxiaoNeural

# =============================================================================
# Analytics & Telemetry
# =============================================================================

# PostHog Analytics
POSTHOG_API_KEY=xxxxx
POSTHOG_HOST=https://app.posthog.com

# Sentry Error Tracking & Performance Monitoring
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_ENABLED=true
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_DEBUG=false
SENTRY_ENABLE_PROFILING=true
SENTRY_SERVER_NAME=

# OpenTelemetry
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4318

# =============================================================================
# Application Settings
# =============================================================================

# Default AI provider (claude, openai, gemini, minimax, moonshot, glm, deepseek)
DEFAULT_PROVIDER=claude

# Default model
DEFAULT_MODEL=claude-sonnet-4-20250514

# Default language (en, zh)
DEFAULT_LANGUAGE=zh

# Default theme (light, dark, auto)
DEFAULT_THEME=auto

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Data directory
DATA_DIR=~/.nexus

# =============================================================================
# Development Settings
# =============================================================================

# Node environment
NODE_ENV=production

# Enable debug mode
DEBUG=false

# Development server URL
DEV_SERVER_URL=http://localhost:5173
