{
  "port": 8080,
  "host": "127.0.0.1",
  "auth": {
    "jwtSecret": "",
    "publicPaths": [
      "/health",
      "/metrics",
      "/api/auth/login"
    ]
  },
  "rateLimit": {
    "windowMs": 60000,
    "maxRequests": 100,
    "authenticatedMultiplier": 10
  },
  "cors": {
    "allowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "timeout": 30000
}
